{
  "name": "functions",
  "description": "Cloud Functions for Feelio (Gemini chat proxy)",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",

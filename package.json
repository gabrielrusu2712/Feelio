{
  "name": "feelio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "husky",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "type-check": "tsc -b",
    "prettier": "prettier --check 'src/**/*.{js,jsx,ts,tsx}'",
    "prettier:fix": "prettier --write 'src/**/*.{js,jsx,ts,tsx}'",
    "knip:all": "knip",
    "knip:required": "knip --files --exports",
    "design-tokens": "yarn design-tokens:preprocess && yarn design-tokens:build && yarn design-tokens:types",
    "design-tokens:preprocess": "rimraf style-dictionary/tokens/processed && tsx style-dictionary/scripts/preprocess-tokens.ts",
    "design-tokens:build": "rimraf src/core/theme/tokens/css && tsx style-dictionary/config.ts",
    "design-tokens:types": "rimraf src/core/theme/tokens/defaults src/core/theme/types/generated && tsx style-dictionary/scripts/generate-types.ts && yarn prettier:fix"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@reduxjs/toolkit": "^2.12.0",
    "@types/leaflet": "^1.9.21",
    "firebase": "^12.14.0",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "leaflet": "^1.9.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-redux": "^9.3.0",
    "react-router": "^7.16.0",
    "redux-persist": "^6.0.0",
    "styled-components": "^6.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-admin": "^14.1.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.15.0",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "3.8.4",
    "rimraf": "^6.1.3",
    "style-dictionary": "^5.4.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}
